# ============================================================
# YUKIKO — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
NODE_ENV=development
APP_URL=http://localhost:3000
ADMIN_SECRET=change_me_in_production

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/yukikoDb?sslmode=require

# Redis (for caching & rate limiting)
REDIS_URL=redis://localhost:6379

# ── Discord ──────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_test_guild_id

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── WhatsApp (Baileys) ────────────────────────────────────────
# No token needed — uses QR code auth. Session stored in:
WHATSAPP_SESSION_PATH=./sessions/whatsapp

# ── AI APIs ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Media APIs ────────────────────────────────────────────────
TENOR_API_KEY=your_tenor_api_key
GIPHY_API_KEY=your_giphy_api_key
REDGIFS_CLIENT_ID=your_redgifs_client_id
REDGIFS_CLIENT_SECRET=your_redgifs_client_secret

# ── Adult Content (Danbooru / Gelbooru) ───────────────────────
DANBOORU_LOGIN=your_danbooru_login
DANBOORU_API_KEY=your_danbooru_api_key

# ── Auth (NextAuth) ───────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret



# ── Homelab Agent ──────────────────────────────────────────
HOMELAB_AGENT_URL=http://100.66.214.108:3001  # IP Tailscale del homelab

# ============================================================
# YUKIKO — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Neon PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require

# ── Admin ─────────────────────────────────────────────────────
ADMIN_SECRET=change_me_in_production

# ── Discord ───────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id
# Solo para desarrollo (guild commands instantáneos):
# DISCORD_GUILD_ID=your_test_guild_id

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── Mobile (WebSocket) ────────────────────────────────────────
MOBILE_WS_PORT=3002

# ── AI — Ollama (self-hosted) ─────────────────────────────────
# Ollama debe estar corriendo en el homelab
OLLAMA_MODEL=llama3.2:3b

# ── Media — Giphy (roleplay GIFs) ────────────────────────────
GIPHY_API_KEY=your_giphy_api_key

# ── Adult Content — Gelbooru ──────────────────────────────────
GELBOORU_API_KEY=your_gelbooru_api_key
GELBOORU_USER_ID=your_gelbooru_user_id

# ── Auth (NextAuth) ───────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ── Homelab Agent ─────────────────────────────────────────────
# Expuesto públicamente via Tailscale Funnel
# En desarrollo: http://localhost:3001 (local)
# En producción: https://your-homelab-domain.com (public via Tailscale)
HOMELAB_AGENT_URL=http://localhost:3001

# ── Wake-on-LAN (WoL) ─────────────────────────────────────────────
# Servicio para despertar el homelab si está apagado
WOL_ENDPOINT=https://your-wol-service.com/wake/device-name

# ── Música — Lavalink (opcional, pendiente de implementar) ────
# LAVALINK_PASSWORD=your_lavalink_password

# ── Monitorización — Grafana (opcional) ──────────────────────
# GRAFANA_ADMIN_PASSWORD=your_grafana_password

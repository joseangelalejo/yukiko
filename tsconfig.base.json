{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@yukiko/core": ["./core/src/index.ts"],
      "@yukiko/core/*": ["./core/src/*"]
    }
  },
  "include": ["core/**/*", "modules/**/*", "platforms/**/*", "db/**/*", "ssh-cli/**/*"],
  "exclude": ["node_modules", "dist", "web"]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["core/**/*", "modules/**/*", "platforms/**/*", "db/**/*", "ssh-cli/**/*"],
  "exclude": ["node_modules", "dist", "web", "yukiko-mobile", "platforms/whatsapp"]
}
